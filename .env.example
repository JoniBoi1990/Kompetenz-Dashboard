# Copy to .env and fill in your values
DOMAIN=localhost:8000

# Azure AD (Entra ID)
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_TENANT_ID=your-tenant-id

# Session signing key — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me

# SharePoint site ID for Microsoft Lists (competency records)
# Find via: GET https://graph.microsoft.com/v1.0/sites?search=schule
SHAREPOINT_SITE_ID=

# Bookings
USE_BOOKINGS_API=false
BOOKINGS_BUSINESS_ID=
BOOKINGS_PAGE_URL=

# Initial admin for first-time setup (can be removed after adding teachers via /admin/teachers)
INITIAL_ADMIN_UPN=jonas.haut@birklehof.de
